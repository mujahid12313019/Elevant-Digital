# =============================================================================
# GEMINI EMBEDDING CONFIGURATION
# =============================================================================
# These settings control how the RAG pipeline handles Gemini API rate limits
# and batch processing

# Maximum embedding requests per minute (Gemini free tier: 100/min)
# Setting to 80 provides a safe margin of 20 requests for retries
EMBED_REQUESTS_PER_MINUTE=80

# Chunks to process per batch (smaller = more frequent API calls)
# Recommended: 5-20 (more = fewer requests, but higher memory usage)
EMBED_BATCH_SIZE=10

# Maximum retry attempts before giving up on a chunk
# Each retry uses exponential backoff: 2^n * 1000ms + jitter
EMBED_MAX_RETRIES=5

# Optional: Static delay between requests (ms)
# Usually not needed - rate limiter handles this automatically
# EMBED_DELAY_MS=100

# =============================================================================
# MONGODB CONFIGURATION (for resumable ingestion)
# =============================================================================
# Connection string for MongoDB Atlas or local instance
# Format: mongodb+srv://user:pass@cluster.mongodb.net/database
# Leave empty to disable resumable ingestion (will still work but not resumable)
# 
# Example: mongodb+srv://user:password@cluster0.xyz.mongodb.net/rag_system
# MONGODB_URI=your-connection-string-here

# Database name (default: rag_system)
MONGODB_DB_NAME=rag_system

# =============================================================================
# QDRANT VECTOR DATABASE
# =============================================================================
QDRANT_URL=https://691db681-f472-4d58-8d10-51e92270b8c5.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-api-key-here

# =============================================================================
# GEMINI API
# =============================================================================
GEMINI_API_KEY=your-api-key-here

# =============================================================================
# SERVER
# =============================================================================
PORT=3000
